# BuildKit picks this up when -f claude-container/Dockerfile is used.
# Keep the build context minimal — only paths the Dockerfile COPYs from.
*
!claude-container/Dockerfile
!claude-container/mcp.json
!claude-container/entrypoint.sh
!claude-container/platform-mcp
claude-container/platform-mcp/**/__pycache__
claude-container/platform-mcp/**/*.egg-info
!claude-container/mcp-auth-proxy
claude-container/mcp-auth-proxy/**/__pycache__
claude-container/mcp-auth-proxy/**/*.egg-info
